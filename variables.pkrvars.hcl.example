# Copy this file to variables.pkrvars.hcl and fill in your values.
# variables.pkrvars.hcl is git-ignored to prevent committing secrets.

image_name = "ubuntu-base"

# ── AWS ──────────────────────────────────────────────────────────────────────
# Credentials: standard AWS chain (~/.aws/credentials, env vars, instance profile)
aws_region        = "us-east-1"
aws_instance_type = "t3.micro"

# ── GCP ──────────────────────────────────────────────────────────────────────
# Credentials: gcloud auth application-default login
gcp_project_id   = "your-gcp-project-id"
gcp_zone         = "us-central1-a"
gcp_machine_type = "e2-medium"

# ── Azure ─────────────────────────────────────────────────────────────────────
# Credentials: az login (or service principal env vars ARM_CLIENT_ID etc.)
# The resource group must exist before the build.
azure_subscription_id = "your-azure-subscription-id"
azure_resource_group  = "packer-images"
azure_location        = "East US"

# ── DigitalOcean ──────────────────────────────────────────────────────────────
do_api_token = "your-do-api-token"
do_region    = "nyc3"

# ── Hetzner ───────────────────────────────────────────────────────────────────
hcloud_token    = "your-hcloud-api-token"
hcloud_location = "nbg1"
